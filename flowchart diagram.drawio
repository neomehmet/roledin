        <mxCell id="F9OWhMPOVOp-ruxTQaYP-1" value="top_function&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;visited_hücre_id = list &lt;b&gt;# &lt;/b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;hücre means bay in power gird&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;visited&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;_ayirici_id,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;visited&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;_ayirici_coords = list, list &lt;b&gt;# &lt;/b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;ayirici means isolator-disconnectior in power grid&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;queue_hücre_id = list &lt;b&gt;#&lt;/b&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;b&gt; &lt;/b&gt;hücre means bay in electrical power gird&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 11px; white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span style=&quot;font-size: 11px; background-color: initial;&quot;&gt;queue&lt;/span&gt;&lt;span style=&quot;font-size: 11px; background-color: initial;&quot;&gt;_ayirici_id,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 11px; background-color: initial;&quot;&gt;queue&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;_ayirici_coords = list, list &lt;/span&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;#&lt;/b&gt; &lt;/font&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;ayirici is isolator-disconnectir electrical power gird&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;span style=&quot;fo